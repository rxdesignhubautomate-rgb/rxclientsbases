{
  "name": "rx-communication-crm",
  "version": "2.0.0",
  "private": true,
  "description": "Channel-independent customer communication and business operations platform for RX Design Hub",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node tests/smoke-start.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "node --check src/server.js",
    "migrate:audit": "node src/scripts/audit-existing-data.js",
    "migrate:backfill-contacts": "node src/scripts/backfill-contact-ids.js",
    "migrate:backfill-conversations": "node src/scripts/backfill-conversations.js",
    "migrate:backfill-messages": "node src/scripts/backfill-messages.js",
    "migrate:verify": "node src/scripts/verify-migration.js",
    "seed:channel": "node src/scripts/seed-channel-account.js",
    "seed:admin": "node src/scripts/create-admin-user.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^14.2.0",
    "helmet": "^8.1.0",
    "openai": "^4.77.0",
    "pdfkit": "^0.16.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "ulid": "^3.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "supertest": "^7.0.0",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "jose": "^5.10.0"
  }
}